{
  "name": "backend",
  "version": "0.0.1",
  "description": "backend for Fake News Generator",
  "author": {
    "name": "Dmitri Atamaniuc",
    "email": "d.atamaniuc@gmail.com",
    "url": "https://dynosoft.md"
  },
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "pnpm --dir ../.. --filter @fakenews/shared build && nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "NEST_DEBUG=true nest start --debug 0.0.0.0:9229 --watch",
    "start:prod": "node dist/main",
    "repl": "nest start --entryFile repl",
    "spelunker": "nest start --entryFile spelunker",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "prisma:generate": "prisma generate --schema ./prisma/schema.prisma",
    "prisma:studio": "prisma studio --schema ./prisma/schema.prisma --hostname 0.0.0.0 --port 5555",
    "migrate:dev": "prisma migrate dev --schema ./prisma/schema.prisma",
    "migrate:deploy": "prisma migrate deploy --schema ./prisma/schema.prisma",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:cov": "vitest run --coverage",
    "test:debug": "vitest --inspect-brk --inspect --logHeapUsage --threads=false",
    "test:e2e": "vitest run --config ./vitest.config.e2e.ts"
  },
  "dependencies": {
    "@nestjs/config": "^4.0.2",
    "@nestjs/common": "^11.0.1",
    "@nestjs/core": "^11.0.1",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/schedule": "^6.0.0",
    "@fakenews/shared": "workspace:*",
    "@prisma/client": "^6.16.0",
    "axios": "^1.12.2",
    "bullmq": "^5.58.5",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "cron": "^4.3.3",
    "ioredis": "^5.8.0",
    "joi": "^18.1.2",
    "openai": "^5.16.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "xml2js": "^0.6.2"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@types/express": "^5.0.0",
    "@types/xml2js": "^0.4.14",
    "@types/node": "^22.10.7",
    "@types/supertest": "^6.0.2",
    "@swc/cli": "^0.8.1",
    "@swc/core": "^1.15.24",
    "@vitest/coverage-v8": "^4.1.3",
    "chokidar": "^5.0.0",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^16.0.0",
    "prettier": "^3.4.2",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0",
    "unplugin-swc": "^1.5.9",
    "vitest": "^4.1.3",
    "prisma": "^6.16.0",
    "nestjs-spelunker": "^1.1.0"
  }
}
